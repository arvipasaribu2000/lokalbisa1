# Copy file ini ke .env untuk testing lokal (jangan pernah commit .env asli ke git!)

# Wajib untuk AI Compliance Guide generatif
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Wajib untuk OTP WhatsApp (daftar gratis di fonnte.com, ambil token dari dashboard)
FONNTE_TOKEN=

# Wajib untuk OTP & Sinkronisasi Firestore
# Isi dengan base64 dari file service-account.json Firebase kamu, contoh cara generate:
#   base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT=

# Opsional — garam tambahan untuk hash OTP (boleh string random apa saja)
OTP_SALT=ganti-dengan-string-acak-kamu-sendiri

# Wajib untuk Login Sidik Jari (WebAuthn)
# RP_ID = domain PWA kamu TANPA https:// dan TANPA path, contoh: arvipasaribu2000.github.io
# RP_ORIGIN = origin lengkap PWA kamu, contoh: https://arvipasaribu2000.github.io
RP_NAME=LOKALBISA
RP_ID=
RP_ORIGIN=

PORT=8080
